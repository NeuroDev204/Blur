{
  "realm": "blur",
  "enabled": true,
  "sslRequired": "none",
  "attributes": {
    "userProfileEnabled": "true",
    "unmanagedAttributePolicy": "ENABLED"
  },
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 360000,
  "ssoSessionMaxLifespan": 360000,
  "offlineSessionIdleTimeout": 2592000,
  "defaultSignatureAlgorithm": "RS256",
  "roles": {
    "realm": [
      {
        "name": "USER",
        "description": "Default user role"
      },
      {
        "name": "ADMIN",
        "description": "Administrator role"
      }
    ]
  },
  "defaultRole": {
    "name": "default-roles-blur",
    "composites": {
      "realm": [
        "USER"
      ]
    }
  },
  "clients": [
    {
      "clientId": "blur-web-app",
      "name": "Blur Web Application",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://blur.io.vn/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://blur.io.vn"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "blur-user-id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "blurUserId",
            "claim.name": "blur_user_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "jsonType.label": "String"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_roles",
            "multivalued": "true",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "blur-api-gateway",
      "name": "Blur API Gateway",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "secret": "4X4fb7xmR5jGjkNp0jVKtGOKbHmLtkHY",
      "redirectUris": [
        "http://localhost:8888/*"
      ],
      "webOrigins": [
        "http://localhost:8888"
      ],
      "protocolMappers": [
        {
          "name": "blur-user-id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "blurUserId",
            "claim.name": "blur_user_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "jsonType.label": "String"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_roles",
            "multivalued": "true",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "blur-service-account",
      "name": "Blur Service Account",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "secret": "7eYfXF74ClREz7KeFHFacb8QlUkvxYx1"
    }
  ],
  "users": [
    {
      "username": "service-account-blur-service-account",
      "enabled": true,
      "serviceAccountClientId": "blur-service-account",
      "clientRoles": {
        "realm-management": ["manage-users", "view-users", "query-users"]
      }
    }
  ],
  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "name": "declarative-user-profile",
        "providerId": "declarative-user-profile",
        "subComponents": {},
        "config": {
          "kc.user.profile.config": [
            "{\"attributes\":[{\"name\":\"username\"},{\"name\":\"email\"},{\"name\":\"firstName\"},{\"name\":\"lastName\"},{\"name\":\"blurUserId\",\"displayName\":\"Blur User ID\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\"]},\"validations\":{}}],\"unmanagedAttributePolicy\":\"ENABLED\"}"
          ]
        }
      }
    ]
  },
  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "${GOOGLE_CLIENT_ID}",
        "clientSecret": "${GOOGLE_CLIENT_SECRET}",
        "defaultScope": "openid email profile",
        "syncMode": "IMPORT"
      }
    }
  ]
}